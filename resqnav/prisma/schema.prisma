// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  role      String     @default("CITIZEN") // CITIZEN, DISPATCHER, GOV, ADMIN
  credits   Int        @default(100)
  phone     String?
  badge     String     @default("bronze") // bronze, silver, gold, platinum
  reports   Incident[] @relation("ReportedIncidents")
  payments  Payment[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Ambulance {
  id        String   @id @default(uuid())
  callSign  String   @unique
  driver    String
  phone     String?
  status    String   @default("AVAILABLE") // AVAILABLE, EN_ROUTE, STANDBY, MAINTENANCE
  lat       Float?
  lng       Float?
  routes    Route[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Incident {
  id          String   @id @default(uuid())
  type        String   // ACCIDENT, CONGESTION, FLOOD, ROADBLOCK
  severity    String   // LOW, MEDIUM, HIGH, CRITICAL
  description String?
  lat         Float
  lng         Float
  location    String
  verified    Boolean  @default(false)
  reporterId  String
  reporter    User     @relation("ReportedIncidents", fields: [reporterId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Route {
  id          String    @id @default(uuid())
  type        String    // EMERGENCY, REROUTE
  ambulanceId String?
  ambulance   Ambulance? @relation(fields: [ambulanceId], references: [id])
  fromLat     Float
  fromLng     Float
  toLat       Float
  toLng       Float
  fromLoc     String?
  toLoc       String?
  etaMin      Int?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Float
  type      String   // CREDIT_PURCHASE, BOOKING, PENALTY, REWARD
  status    String   @default("PENDING") // PENDING, SUCCESS, FAILED
  reference String?  @unique // Razorpay payment ID
  createdAt DateTime @default(now())
}
